RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# spec 025 (#417) — Apple iCloud CalDAV provider
# 32바이트 base64 인코딩 키. dev/preview/production 별도 키 사용.
# 생성: openssl rand -base64 32
APPLE_PASSWORD_ENCRYPTION_KEY=your_32_byte_base64_key_here

# spec 057 — 사용자 분석(GA4)
# GA4 측정 ID. 미설정 시 분석 태그가 붙지 않고 앱은 정상 동작.
# GA4 콘솔 > 관리 > 데이터 스트림에서 발급(G-XXXXXXX).
NEXT_PUBLIC_GA_ID=

# spec 057 — 검색 노출(Google Search Console) 소유 확인
# GSC 속성 등록 시 받는 HTML 태그 확인값(content 값만). 미설정 시 메타 미출력.
GOOGLE_SITE_VERIFICATION=

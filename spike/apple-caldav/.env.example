# 본 파일을 .env.local로 복사한 뒤 값을 채운다.
# .env.local은 .gitignore에 포함되어 push되지 않는다.

# Apple ID (이메일 형식). 2단계 인증이 활성화되어 있어야 한다.
APPLE_ID=

# App-Specific Password (16자리, 하이픈 포함 또는 미포함 모두 허용)
# 발급: https://appleid.apple.com → 로그인 및 보안 → 앱 암호 → 암호 생성
# 라벨 권장: "trip-planner-poc"
APPLE_APP_PASSWORD=

# 측정용 자유 문자열. Mermaid·문서에 표기될 식별자. 기본값 사용 무방.
POC_RUN_LABEL=run-1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth.js v5 표준 모델 (@auth/prisma-adapter)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts                    Account[]
  sessions                    Session[]
  createdTrips                Trip[]                       @relation("TripCreator")
  updatedTrips                Trip[]                       @relation("TripUpdater")
  tripMembers                 TripMember[]
  personalAccessTokens        PersonalAccessToken[]
  gcalLinks                   GCalLink[]
  ownedCalendarLinks          TripCalendarLink[]           @relation("TripCalendarLinkOwner")
  memberCalendarSubscriptions MemberCalendarSubscription[] @relation("MemberCalendarSubscriptionUser")
  appleCalendarCredential     AppleCalendarCredential?     @relation("AppleCalendarCredentialUser")
  triggeredImportRuns         ImportRun[]                  @relation("ImportRunTriggeredByUser")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// 비즈니스 모델 (Trip, Day, Member, Invitation)
// ============================================================

model Trip {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  // spec 029 T051 (#601, v3.0.0) — 명목 startDate/endDate 컬럼은 contract
  // 단계에서 제거. 시작·종료 날짜는 등록된 Day 의 min/max 에서 derive 한다
  // (`src/lib/trip-period.ts::getDerivedPeriod`).
  createdBy   String   @map("created_by")
  updatedBy   String   @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  creator        User              @relation("TripCreator", fields: [createdBy], references: [id])
  updater        User              @relation("TripUpdater", fields: [updatedBy], references: [id])
  days           Day[]
  tripMembers    TripMember[]
  gcalLinks      GCalLink[]
  calendarLink   TripCalendarLink?
  activityDrafts ActivityDraft[]
  importRuns     ImportRun[]

  @@map("trips")
}

model Day {
  id      Int      @id @default(autoincrement())
  tripId  Int      @map("trip_id")
  date    DateTime @db.Timestamptz(3)
  title   String?
  content String?  @db.Text

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities     Activity[]
  activityDrafts ActivityDraft[]

  @@unique([tripId, date])
  @@index([tripId, date])
  @@map("days")
}

// ============================================================
// Activity (일정 내 구조화된 활동)
// ============================================================

enum ActivityCategory {
  SIGHTSEEING
  DINING
  TRANSPORT
  ACCOMMODATION
  SHOPPING
  OTHER
}

enum ReservationStatus {
  REQUIRED
  RECOMMENDED
  ON_SITE
  NOT_NEEDED
  RESERVED
}

model Activity {
  id                Int                @id @default(autoincrement())
  dayId             Int                @map("day_id")
  category          ActivityCategory
  title             String
  startTime         DateTime?          @map("start_time") @db.Timestamptz(3)
  startTimezone     String?            @map("start_timezone") @db.VarChar(40)
  endTime           DateTime?          @map("end_time") @db.Timestamptz(3)
  endTimezone       String?            @map("end_timezone") @db.VarChar(40)
  location          String?
  memo              String?            @db.Text
  url               String?            @db.Text
  cost              Decimal?           @db.Decimal(10, 2)
  currency          String             @default("EUR") @db.VarChar(3)
  reservationStatus ReservationStatus? @map("reservation_status")
  allDay            Boolean            @default(false) @map("is_all_day")
  sortOrder         Int                @default(0) @map("sort_order")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  day                       Day                        @relation(fields: [dayId], references: [id], onDelete: Cascade)
  gcalEventMappings         GCalEventMapping[]
  tripCalendarEventMappings TripCalendarEventMapping[] @relation("TripCalendarEventMappingActivity")
  promotedFromDraft         ActivityDraft?             @relation("ActivityDraftPromoted")

  @@index([dayId, startTime])
  @@index([dayId, sortOrder])
  @@map("activities")
}

enum TripRole {
  OWNER
  HOST
  GUEST
}

model TripMember {
  id       Int      @id @default(autoincrement())
  tripId   Int      @map("trip_id")
  userId   String   @map("user_id")
  role     TripRole @default(GUEST)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(3)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_members")
}

// Invitation 테이블 삭제 — JWT 토큰 기반 초대로 대체 (D-007)

// ============================================================
// Personal Access Token (외부 클라이언트 API 인증)
// ============================================================

// ============================================================
// Google Calendar 연동 (#305, spec 018)
// ============================================================

enum GCalCalendarType {
  DEDICATED
  PRIMARY
}

// spec 024 (#416): provider 추상화 도입. GOOGLE 외에 APPLE 등 후속 가능.
enum CalendarProviderId {
  GOOGLE
  APPLE
}

model GCalLink {
  id           Int                @id @default(autoincrement())
  userId       String             @map("user_id")
  tripId       Int                @map("trip_id")
  provider     CalendarProviderId @default(GOOGLE) // spec 024 expand
  calendarId   String             @map("calendar_id")
  calendarType GCalCalendarType   @map("calendar_type")
  calendarName String?            @map("calendar_name")
  lastSyncedAt DateTime?          @map("last_synced_at") @db.Timestamptz(3)
  lastError    String?            @map("last_error")
  skippedCount Int                @default(0) @map("skipped_count")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip          Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventMappings GCalEventMapping[]

  @@unique([userId, tripId])
  @@index([tripId])
  @@map("gcal_links")
}

model GCalEventMapping {
  id            Int      @id @default(autoincrement())
  linkId        Int      @map("link_id")
  activityId    Int      @map("activity_id")
  googleEventId String   @map("google_event_id")
  syncedEtag    String   @map("synced_etag")
  lastSyncedAt  DateTime @map("last_synced_at") @db.Timestamptz(3)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  link     GCalLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([linkId, activityId])
  @@map("gcal_event_mappings")
}

// ============================================================
// Trip Calendar 공유 (spec 019, Epic #349)
// v2.9.0 expand: per-trip 공유 캘린더 모델. 레거시 GCalLink/GCalEventMapping은 병존.
// 후속 릴리즈에서 contract로 제거 예정.
// ============================================================

enum MemberCalendarSubscriptionStatus {
  NOT_ADDED
  ADDED
  ERROR
}

model TripCalendarLink {
  id           Int                @id @default(autoincrement())
  tripId       Int                @unique @map("trip_id")
  ownerId      String             @map("owner_id")
  provider     CalendarProviderId @default(GOOGLE) // spec 024 expand
  calendarId   String             @map("calendar_id")
  calendarName String?            @map("calendar_name")
  lastSyncedAt DateTime?          @map("last_synced_at") @db.Timestamptz(3)
  lastError    String?            @map("last_error")
  skippedCount Int                @default(0) @map("skipped_count")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  trip          Trip                         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  owner         User                         @relation("TripCalendarLinkOwner", fields: [ownerId], references: [id])
  subscriptions MemberCalendarSubscription[]
  eventMappings TripCalendarEventMapping[]

  @@index([ownerId])
  @@map("trip_calendar_links")
}

// 이벤트 매핑 정본 (spec 022 v2.10.0). 레거시 GCalEventMapping은 병존하되 활성 쓰기는 없다.
model TripCalendarEventMapping {
  id                 Int      @id @default(autoincrement())
  tripCalendarLinkId Int      @map("trip_calendar_link_id")
  activityId         Int      @map("activity_id")
  googleEventId      String   @map("google_event_id")
  syncedEtag         String   @map("synced_etag")
  lastSyncedAt       DateTime @map("last_synced_at") @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  link     TripCalendarLink @relation(fields: [tripCalendarLinkId], references: [id], onDelete: Cascade)
  activity Activity         @relation("TripCalendarEventMappingActivity", fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([tripCalendarLinkId, activityId])
  @@index([tripCalendarLinkId])
  @@map("trip_calendar_event_mappings")
}

// spec 025 (#417) — Apple iCloud CalDAV 자격증명. AES-256-GCM 암호화된 app-specific password 저장.
model AppleCalendarCredential {
  userId            String    @id @map("user_id")
  appleId           String    @map("apple_id")
  encryptedPassword String    @map("encrypted_password") // base64(ciphertext + auth tag)
  iv                String // base64(12바이트 random)
  lastValidatedAt   DateTime? @map("last_validated_at") @db.Timestamptz(3)
  lastError         String?   @map("last_error")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation("AppleCalendarCredentialUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("apple_calendar_credentials")
}

model MemberCalendarSubscription {
  id        Int                              @id @default(autoincrement())
  linkId    Int                              @map("link_id")
  userId    String                           @map("user_id")
  status    MemberCalendarSubscriptionStatus @default(NOT_ADDED)
  lastError String?                          @map("last_error")
  createdAt DateTime                         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(3)

  link TripCalendarLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user User             @relation("MemberCalendarSubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([linkId, userId])
  @@index([userId])
  @@map("member_calendar_subscriptions")
}

// ============================================================
// Personal Access Token (외부 클라이언트 API 인증)
// ============================================================

// ============================================================
// 외부 캘린더 import (spec 027, ADR 0006, v2.15.0)
// 외부 → 내부 단방향. trip 캘린더 정본(ADR 0003)은 그대로 유지.
// ============================================================

enum ActivityDraftStatus {
  PENDING
  PROMOTED
  DELETED
}

model ActivityDraft {
  id     Int  @id @default(autoincrement())
  tripId Int  @map("trip_id")
  dayId  Int? @map("day_id")

  // 외부 출처 식별
  provider           CalendarProviderId
  externalCalendarId String             @map("external_calendar_id")
  externalEventId    String             @map("external_event_id")

  // 매핑 가능 필드 (외부 → 자동 채움)
  title        String
  startTime    DateTime @map("start_time") @db.Timestamptz(3)
  endTime      DateTime @map("end_time") @db.Timestamptz(3)
  isAllDay     Boolean  @default(false) @map("is_all_day")
  locationText String?  @map("location_text")
  description  String?  @db.Text

  // 매핑 불가 필드 (사용자 보강 대상)
  startTimezone String? @map("start_timezone") @db.VarChar(40)
  endTimezone   String? @map("end_timezone") @db.VarChar(40)

  // 상태
  status               ActivityDraftStatus @default(PENDING)
  promotedToActivityId Int?                @unique @map("promoted_to_activity_id")

  // 메타
  importRunId     Int       @map("import_run_id")
  lastRefreshedAt DateTime? @map("last_refreshed_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  trip               Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day                Day?      @relation(fields: [dayId], references: [id], onDelete: SetNull)
  promotedToActivity Activity? @relation("ActivityDraftPromoted", fields: [promotedToActivityId], references: [id], onDelete: SetNull)
  importRun          ImportRun @relation(fields: [importRunId], references: [id], onDelete: Restrict)

  @@unique([provider, externalCalendarId, externalEventId])
  @@index([tripId, status])
  @@map("activity_drafts")
}

model ImportRun {
  id                 Int                @id @default(autoincrement())
  tripId             Int                @map("trip_id")
  triggeredByUserId  String             @map("triggered_by_user_id")
  provider           CalendarProviderId
  externalCalendarId String             @map("external_calendar_id")
  importedCount      Int                @default(0) @map("imported_count")
  skippedCount       Int                @default(0) @map("skipped_count")
  failedCount        Int                @default(0) @map("failed_count")
  failedTitles       String[]           @map("failed_titles")
  startedAt          DateTime           @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt         DateTime?          @map("finished_at") @db.Timestamptz(3)

  trip            Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  triggeredByUser User            @relation("ImportRunTriggeredByUser", fields: [triggeredByUserId], references: [id])
  drafts          ActivityDraft[]

  @@index([tripId, startedAt])
  @@map("import_runs")
}

// ============================================================
// Personal Access Token (외부 클라이언트 API 인증)
// ============================================================

model PersonalAccessToken {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  name        String
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix") @db.VarChar(11)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("personal_access_tokens")
}

{
  "$schema": "https://tokens.studio/schemas/design-tokens.json",
  "_description": "Trip Planner design tokens. Edit via Figma Tokens Studio plugin or hand; regenerate CSS with `npm run tokens:build`.",
  "color": {
    "primary": {
      "50":  { "$value": "#eff8ff", "$type": "color" },
      "100": { "$value": "#dbeffe", "$type": "color" },
      "200": { "$value": "#b9e0fd", "$type": "color" },
      "300": { "$value": "#7bcbfb", "$type": "color" },
      "400": { "$value": "#38adf6", "$type": "color" },
      "500": { "$value": "#0e90e0", "$type": "color" },
      "600": { "$value": "#0272be", "$type": "color" },
      "700": { "$value": "#035b9a", "$type": "color" },
      "800": { "$value": "#074e7f", "$type": "color" },
      "900": { "$value": "#0c4169", "$type": "color" }
    },
    "surface": {
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f8fafc", "$type": "color" },
      "100": { "$value": "#f1f5f9", "$type": "color" },
      "200": { "$value": "#e2e8f0", "$type": "color" },
      "300": { "$value": "#cbd5e1", "$type": "color" },
      "400": { "$value": "#94a3b8", "$type": "color" },
      "500": { "$value": "#64748b", "$type": "color" },
      "600": { "$value": "#475569", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color" },
      "800": { "$value": "#1e293b", "$type": "color" },
      "900": { "$value": "#0f172a", "$type": "color" }
    },
    "sky": {
      "50":  { "$value": "#f0f9ff", "$type": "color" },
      "100": { "$value": "#e0f2fe", "$type": "color" },
      "200": { "$value": "#bae6fd", "$type": "color" },
      "500": { "$value": "#0ea5e9", "$type": "color" },
      "600": { "$value": "#0284c7", "$type": "color" },
      "700": { "$value": "#0369a1", "$type": "color" }
    }
  },
  "radius": {
    "card": { "$value": "0.625rem", "$type": "dimension" }
  },
  "shadow": {
    "card":       { "$value": "0 0 0 1px rgb(15 23 42 / 0.08), 0 1px 3px rgb(15 23 42 / 0.06)", "$type": "shadow" },
    "card-hover": { "$value": "0 0 0 1px rgb(15 23 42 / 0.14), 0 2px 6px rgb(15 23 42 / 0.08)", "$type": "shadow" },
    "fab":        { "$value": "0 2px 8px rgb(15 23 42 / 0.18)", "$type": "shadow" }
  },
  "max-width": {
    "content": { "$value": "40rem", "$type": "dimension" }
  }
}
